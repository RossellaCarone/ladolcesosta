---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import MobileMenu from '../components/MobileMenu.tsx';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import About from '../components/About.astro';
import PhotoCarousel from '../components/PhotoCarousel.tsx';
import Territory from '../components/Territory.astro';

import Booking from '../components/Booking.astro';
import Reviews from '../components/Reviews.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout>
  <div id="scroll-progress"></div>
  <Nav />
  <main id="main">
  <MobileMenu client:media="(max-width: 900px)" />
  <Hero />
  <Stats />
  <About />

  <!-- Galleria fotografica -->
  <section id="galleria" class="py-20 md:py-28 bg-earth">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <div class="text-center mb-12 reveal">
        <h2 class="font-serif text-4xl md:text-5xl text-cream mb-4">I nostri spazi</h2>
        <p class="font-sans text-cream/70 text-lg">Scopri ogni angolo de La Dolce Sosta</p>
      </div>
      <div class="reveal">
        <PhotoCarousel client:visible />
      </div>
    </div>
  </section>

  <Territory />

  <Reviews />

  <Booking />

  <Contact />

  </main>
  <Footer />

  <script>
    // Scroll progress bar (throttled with requestAnimationFrame)
    const progressBar = document.getElementById('scroll-progress');
    let progressRafId: number;
    const updateProgress = () => {
      if (!progressBar) return;
      if (progressRafId) return;
      progressRafId = requestAnimationFrame(() => {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        progressBar.style.width = progress + '%';
        progressRafId = 0;
      });
    };
    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();

    // Reveal observer (optimized)
    const revealObs = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
    document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));
  </script>
</BaseLayout>
