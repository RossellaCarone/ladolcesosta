---
import ContactForm from './ContactForm.tsx';
---

<section id="contatti" class="py-20 md:py-28 bg-cream">
  <div class="max-w-5xl mx-auto px-6 md:px-10">
    <div class="text-center mb-14 reveal">
      <p class="font-sans text-xs uppercase tracking-[0.3em] text-earth/60 mb-4">Contatti</p>
      <h2 class="font-serif text-4xl md:text-5xl text-dark mb-3">Contattaci</h2>
      <p class="font-sans text-earth/70 text-lg">Hai domande o richieste? Scrivici, ti risponderemo al più presto</p>
    </div>

    <!-- Form + Mappa affiancati -->
    <div class="grid md:grid-cols-2 gap-8 md:gap-10 items-stretch">
      <!-- Form -->
      <div class="bg-white/60 rounded-2xl p-6 md:p-8 shadow-sm reveal">
        <ContactForm client:visible />
      </div>

      <!-- Google Maps -->
      <div class="rounded-2xl overflow-hidden shadow-sm reveal min-h-[350px]">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3016.3823084131814!2d17.16220157550747!3d40.88542792698113!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1347b7000cdbaebb%3A0x109808b188191ff!2sLa%20dolce%20sosta!5e0!3m2!1sit!2sit!4v1776631844735!5m2!1sit!2sit"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="La Dolce Sosta — Castellana Grotte"
          class="w-full h-full"
        ></iframe>
      </div>
    </div>

    <!-- Info bollini -->
    <div class="mt-8 reveal flex flex-col sm:flex-row items-start sm:items-center justify-center gap-6 sm:gap-10">
      <a href="https://maps.app.goo.gl/5FVy3jdz7Bp3n8Vf9?g_st=iw" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
        <div class="flex-shrink-0 w-9 h-9 rounded-full bg-sand/30 flex items-center justify-center">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-earth"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <p class="font-sans text-sm text-earth/70">Via Luigi Cadorna, 33<br />70013 Castellana Grotte (BA)</p>
      </a>
      <div class="flex items-center gap-3">
        <div class="flex-shrink-0 w-9 h-9 rounded-full bg-sand/30 flex items-center justify-center">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-earth"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </div>
        <a href="mailto:Piero.antonacci29@gmail.com" class="font-sans text-sm text-accent hover:text-earth transition-colors">Piero.antonacci29@gmail.com</a>
      </div>
      <div class="flex items-center gap-3">
        <div class="flex-shrink-0 w-9 h-9 rounded-full bg-sand/30 flex items-center justify-center">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-earth"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </div>
        <div class="flex flex-col">
          <a href="tel:+393428298523" class="font-sans text-sm text-accent hover:text-earth transition-colors">+39 342 829 8523</a>
          <a href="tel:+393664877285" class="font-sans text-sm text-accent hover:text-earth transition-colors">+39 366 487 7285</a>
        </div>
      </div>
    </div>

    <!-- Booking + Airbnb -->
    <div class="mt-6 reveal flex flex-col sm:flex-row items-start sm:items-center justify-center gap-6 sm:gap-10">
      <div class="flex items-center gap-3">
        <div class="flex-shrink-0 w-9 h-9 rounded-full bg-sand/30 flex items-center justify-center">
          <span class="font-sans text-xs font-medium text-earth">B</span>
        </div>
        <a href="https://www.booking.com/hotel/it/la-dolce-sosta-castellana-grotte.it.html" target="_blank" rel="noopener noreferrer" class="font-sans text-sm text-earth/70 hover:text-accent transition-colors">Booking.com</a>
      </div>
      <div class="flex items-center gap-3">
        <div class="flex-shrink-0 w-9 h-9 rounded-full bg-sand/30 flex items-center justify-center">
          <span class="font-sans text-xs font-medium text-earth">A</span>
        </div>
        <a href="https://www.airbnb.it/rooms/1642096504763171753" target="_blank" rel="noopener noreferrer" class="font-sans text-sm text-earth/70 hover:text-accent transition-colors">Airbnb</a>
      </div>
    </div>
  </div>
</section>