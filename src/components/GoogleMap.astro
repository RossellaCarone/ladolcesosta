---
const mapsLink = 'https://www.google.com/maps/search/?api=1&query=Via+Luigi+Cadorna+33+Castellana+Grotte+BA';
const lat = 40.8014;
const lon = 17.1319;
const osmEmbed = `https://www.openstreetmap.org/export/embed.html?bbox=${lon-0.01}%2C${lat-0.01}%2C${lon+0.01}%2C${lat+0.01}&layer=mapnik&marker=${lat}%2C${lon}`;
const osmLink = `https://www.openstreetmap.org/?mlat=${lat}&mlon=${lon}#map=16/${lat}/${lon}`;
---

<section id="mappa" class="py-20 md:py-28 bg-cream">
  <div class="max-w-5xl mx-auto px-6 md:px-10">
    <div class="text-center mb-12 reveal">
      <h2 class="font-serif text-4xl md:text-5xl text-dark mb-4">Dove siamo</h2>
      <p class="font-sans text-earth/70 text-lg">Via Luigi Cadorna, 33 – 70013 Castellana Grotte (BA)</p>
    </div>

    <div class="reveal rounded-2xl overflow-hidden shadow-lg border border-sand/30">
      <iframe
        src={osmEmbed}
        width="100%"
        height="450"
        style="border:0;filter:grayscale(20%) contrast(95%)"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Mappa di La Dolce Sosta"
        class="w-full h-[350px] md:h-[450px]"
      ></iframe>
    </div>

    <p class="text-center mt-4 font-sans text-sm flex flex-col sm:flex-row gap-2 sm:gap-6 justify-center">
      <a href={mapsLink} target="_blank" rel="noopener noreferrer" class="text-accent underline hover:text-earth transition-colors">
        📍 Apri in Google Maps
      </a>
      <a href={osmLink} target="_blank" rel="noopener noreferrer" class="text-accent underline hover:text-earth transition-colors">
        🗺️ Apri in OpenStreetMap
      </a>
    </p>
  </div>
</section>