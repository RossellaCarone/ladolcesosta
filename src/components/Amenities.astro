---
import { amenities } from '../data/amenities';
---

<section id="servizi" class="py-20 md:py-28 bg-earth">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="text-center mb-14 reveal">
      <h2 class="font-serif text-4xl md:text-5xl text-cream mb-4">
        Tutto il comfort di <em>casa</em>
      </h2>
      <p class="font-sans text-cream/70 text-lg">Servizi pensati per rendere il vostro soggiorno indimenticabile</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {amenities.map((a) => (
        <div class="amenity-card reveal group rounded-2xl border border-cream/15 bg-cream/5 p-8 text-center transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:border-accent/50">
          <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-full bg-accent/15 text-accent transition-colors duration-300 group-hover:bg-accent/25">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-7 w-7">
              <path stroke-linecap="round" stroke-linejoin="round" d={a.icon} />
            </svg>
          </div>
          <h3 class="font-serif text-xl text-cream mb-2">{a.title}</h3>
          <p class="font-sans text-sm text-cream/70 leading-relaxed">{a.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
