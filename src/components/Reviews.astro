---
import { reviews } from '../data/reviews';
---

<section id="recensioni" class="py-20 md:py-28 bg-beige relative overflow-hidden">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 text-[12rem] md:text-[18rem] leading-none font-serif text-sand/50 select-none pointer-events-none" aria-hidden="true">
    &ldquo;
  </div>

  <div class="max-w-3xl mx-auto px-6 md:px-10 relative z-10">
    <div class="text-center reveal">
      <p class="font-sans text-base md:text-lg uppercase tracking-[0.3em] text-earth/60 mb-20">Dicono di noi</p>

<div id="reviews-container" class="relative min-h-[280px] md:min-h-[240px]">
        {reviews.map((review, i) => (
          <div class="review-slide absolute inset-0 flex flex-col items-center justify-center transition-opacity duration-1000" data-index={i} style={i === 0 ? 'opacity: 1;' : 'opacity: 0;'}>
            <blockquote class="mb-6 md:mb-10 w-full">
              <p class="font-serif text-lg md:text-2xl lg:text-3xl text-dark leading-relaxed italic">
                &ldquo;{review.text}&rdquo;
              </p>
            </blockquote>

            <div class="flex flex-col items-center gap-4 md:gap-6 mt-8 md:mt-16">
              <p class="font-sans text-base md:text-lg tracking-wide text-dark font-medium">
                {review.author}
              </p>

              <div class="w-8 md:w-12 h-px bg-warm"></div>

              <div class="flex items-center gap-3">
                {review.source === 'Booking.com' ? (
                  <span class="bg-[#003580] text-white font-sans font-bold text-sm md:text-base px-2 py-1 rounded-md">
                    {review.rating}/10
                  </span>
                ) : (
                  <div class="flex gap-0.5">
                    {Array.from({ length: 5 }, (_, i) => (
                      <span class={`text-base md:text-xl ${i < review.rating ? 'text-amber-400' : 'text-sand/40'}`}>★</span>
                    ))}
                  </div>
                )}
                <span class="font-sans text-sm text-earth/70">{review.source}</span>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="flex flex-col items-center gap-4 md:gap-6 mt-12 md:mt-20">
        <a
          href="https://www.booking.com/hotel/it/la-dolce-sosta-castellana-grotte.it.html"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 font-sans text-sm text-earth/70 hover:text-accent transition-colors duration-300 underline underline-offset-4 decoration-earth/30 hover:decoration-accent"
        >
          Leggi tutte le recensioni su Booking.com
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
        <a
          href="https://www.airbnb.it/rooms/1642096504763171753"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 font-sans text-sm text-earth/70 hover:text-accent transition-colors duration-300 underline underline-offset-4 decoration-earth/30 hover:decoration-accent"
        >
          Leggi tutte le recensioni su Airbnb
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
      </div>
    </div>
  </div>

  <script>
    const slides = document.querySelectorAll('.review-slide');
    let currentIndex = 0;

    function showNextReview() {
      slides[currentIndex].style.opacity = '0';
      currentIndex = (currentIndex + 1) % slides.length;
      slides[currentIndex].style.opacity = '1';
    }

    setInterval(showNextReview, 8000);
  </script>
</section>
