---
const year = new Date().getFullYear();
const sections = [
  { label: 'Chi siamo', href: '#about' },
  { label: 'Galleria', href: '#gallery' },
  { label: 'Servizi', href: '#servizi' },
  { label: 'Territorio', href: '#territorio' },
  { label: 'Prenota', href: '#prenota' },
  { label: 'Contatti', href: '#contatti' },
];
---

<footer class="bg-dark text-cream/80 py-16">
  <div class="max-w-6xl mx-auto px-6 md:px-10">
    <div class="grid md:grid-cols-3 gap-12 mb-12">
      <!-- Brand -->
      <div>
        <h3 class="font-serif text-2xl text-cream mb-3">La Dolce Sosta</h3>
        <p class="font-sans text-cream/50 text-sm leading-relaxed">
          Casa vacanze nel cuore di Castellana Grotte, porta d'ingresso alla Valle d'Itria.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="font-sans text-sm font-medium text-cream/60 uppercase tracking-wider mb-4">Sezioni</h4>
        <ul class="space-y-2">
          {sections.map(s => (
            <li>
              <a href={s.href} class="font-sans text-sm text-cream/50 hover:text-cream transition-colors">{s.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Info -->
      <div>
        <h4 class="font-sans text-sm font-medium text-cream/60 uppercase tracking-wider mb-4">Informazioni</h4>
        <div class="space-y-3 font-sans text-sm text-cream/50">
          <p>Via Luigi Cadorna, 33<br />70013 Castellana Grotte (BA)</p>
          <a
            href="https://www.booking.com/hotel/it/la-dolce-sosta-castellana-grotte.it.html"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block hover:text-cream transition-colors"
          >
            Prenota su Booking.com →
          </a>
        </div>
      </div>
    </div>

    <!-- Legal -->
    <div class="border-t border-cream/10 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="font-sans text-xs text-cream/40 text-center md:text-left space-y-1">
          <p>CIN: IT072017C200123181</p>
          <p>CIS: BA07201791000075573</p>
        </div>
        <p class="font-sans text-xs text-cream/40">
          &copy; {year} La Dolce Sosta. Tutti i diritti riservati.
        </p>
      </div>
    </div>
  </div>
</footer>
