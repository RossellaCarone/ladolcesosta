---
import BookingWidget from './BookingWidget.tsx';
---

<section id="prenota" class="py-20 md:py-28 bg-earth">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="text-center mb-12 reveal">
      <h2 class="font-serif text-4xl md:text-5xl text-cream mb-4">Prenota il tuo <em>soggiorno</em></h2>
      <p class="font-sans text-cream/70 text-lg max-w-2xl mx-auto">
        Scegli le date e prenota direttamente su Booking.com per conferma immediata e assistenza dedicata.
      </p>
    </div>

    <div class="reveal">
      <div class="bg-cream/95 rounded-2xl p-6 sm:p-8 shadow-xl overflow-hidden max-w-lg mx-auto">
        <BookingWidget client:visible />
      </div>
    </div>

  </div>
</section>
