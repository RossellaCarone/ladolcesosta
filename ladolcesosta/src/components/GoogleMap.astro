---
const mapSrc = 'https://maps.google.com/maps?q=La+Dolce+Sosta+Via+Luigi+Cadorna+33+Castellana+Grotte&t=&z=15&ie=UTF8&iwloc=&output=embed';
const mapsLink = 'https://www.google.com/maps/search/?api=1&query=Via+Luigi+Cadorna+33+Castellana+Grotte+BA';
---

<section id="mappa" class="py-20 md:py-28 bg-cream">
  <div class="max-w-5xl mx-auto px-6 md:px-10">
    <div class="text-center mb-12 reveal">
      <h2 class="font-serif text-4xl md:text-5xl text-dark mb-4">Dove siamo</h2>
      <p class="font-sans text-earth/70 text-lg">Via Luigi Cadorna, 33 – 70013 Castellana Grotte (BA)</p>
    </div>

    <div class="reveal rounded-2xl overflow-hidden shadow-lg border border-sand/30">
      <iframe
        src={mapSrc}
        width="100%"
        height="400"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="La Dolce Sosta – Castellana Grotte"
        class="w-full h-[350px] md:h-[400px]"
      ></iframe>
    </div>

    <p class="text-center mt-4 font-sans text-sm">
      <a href={mapsLink} target="_blank" rel="noopener noreferrer" class="text-accent underline hover:text-earth transition-colors">
        📍 Apri in Google Maps
      </a>
    </p>
  </div>
</section>
