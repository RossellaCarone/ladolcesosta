---
import { places } from '../data/territory';
import TerritoryModal from './TerritoryModal.tsx';
---

<section id="territorio" class="py-20 md:py-28 bg-beige/40">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="text-center mb-14 reveal">
      <h2 class="font-serif text-4xl md:text-5xl text-dark mb-4">Esplora il territorio</h2>
      <p class="font-sans text-earth/70 text-lg">Meraviglie a pochi chilometri da La Dolce Sosta</p>
    </div>

    <div class="grid md:grid-cols-2 gap-12 items-start">
      <!-- POI List -->
      <div class="reveal">
        <ul class="space-y-3">
          {places.map((place, i) => (
            <li>
              <button
                class="territory-btn w-full text-left px-5 py-4 rounded-xl bg-cream/80 border border-sand/40 hover:border-accent/60 hover:shadow-md transition-all duration-300 group cursor-pointer"
                data-index={i}
              >
                <div class="flex items-center justify-between">
                  <div>
                    <span class="font-serif text-lg text-dark group-hover:text-accent transition-colors">{place.name}</span>
                    <p class="font-sans text-sm text-earth/60 mt-0.5">{place.shortDescription}</p>
                  </div>
                  <span class="font-sans text-sm text-accent font-medium whitespace-nowrap ml-4">{place.distance}</span>
                </div>
              </button>
            </li>
          ))}
        </ul>
      </div>

      <!-- Puglia SVG Map -->
      <div class="reveal flex justify-center">
        <div class="w-full max-w-xs text-accent">
          <svg viewBox="0 0 260 400" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
            <!-- Puglia outline -->
            <path d="M80,20 L95,18 L115,22 L130,30 L145,28 L158,35 L165,45 L170,58 L168,72 L172,85 L180,95 L185,110 L182,125 L188,138 L195,148 L200,162 L198,175 L205,185 L210,195 L215,208 L220,220 L225,232 L228,245 L232,255 L238,262 L242,270 L245,278 L240,285 L232,290 L225,288 L218,282 L212,275 L205,268 L198,262 L192,255 L185,250 L178,245 L172,238 L168,230 L162,222 L155,215 L150,207 L144,200 L138,194 L132,188 L128,180 L122,175 L116,170 L112,162 L108,155 L104,147 L100,140 L96,133 L92,126 L88,118 L85,110 L82,102 L78,94 L75,86 L72,78 L70,68 L68,58 L70,48 L74,36 Z" fill="currentColor" opacity="0.1" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.3"/>
            <!-- Salento -->
            <path d="M198,262 L205,268 L212,275 L218,282 L225,288 L232,290 L240,285 L245,278 L248,290 L246,305 L242,318 L238,328 L232,338 L225,345 L218,350 L212,355 L205,360 L198,365 L192,370 L186,375 L180,378 L174,380 L168,378 L162,372 L158,364 L155,355 L153,344 L152,333 L154,322 L158,312 L164,304 L170,298 L176,292 L182,287 L188,280 L194,273 Z" fill="currentColor" opacity="0.1" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.3"/>
            <!-- Gargano -->
            <path d="M80,94 L75,86 L68,80 L60,76 L52,72 L44,70 L38,68 L34,72 L32,80 L35,88 L40,95 L48,100 L56,104 L64,106 L72,104 L78,100 Z" fill="currentColor" opacity="0.1" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.3"/>
            <!-- Castellana pin with pulse -->
            <circle cx="130" cy="175" r="8" fill="none" stroke="#9c7c4e" stroke-width="1" opacity="0.3">
              <animate attributeName="r" values="8;16;8" dur="2s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.3;0;0.3" dur="2s" repeatCount="indefinite"/>
            </circle>
            <path d="M130,152 C123,152 117,158 117,165 C117,175 130,188 130,188 C130,188 143,175 143,165 C143,158 137,152 130,152 Z" fill="#9c7c4e"/>
            <circle cx="130" cy="165" r="4" fill="#f5f0e8"/>
            <text x="130" y="200" text-anchor="middle" fill="#7a6248" font-size="9" font-weight="600">Castellana Grotte</text>
            <!-- POI dots -->
            <circle cx="118" cy="192" r="3" fill="#b8a07a" opacity="0.7"/>
            <text x="100" y="204" text-anchor="middle" fill="#7a6248" font-size="7">Alberobello</text>
            <circle cx="148" cy="150" r="3" fill="#b8a07a" opacity="0.7"/>
            <text x="162" y="148" fill="#7a6248" font-size="7">Polignano</text>
            <circle cx="172" cy="200" r="3" fill="#b8a07a" opacity="0.7"/>
            <text x="178" y="205" fill="#7a6248" font-size="7">Ostuni</text>
            <circle cx="112" cy="198" r="3" fill="#b8a07a" opacity="0.7"/>
            <text x="96" y="212" text-anchor="middle" fill="#7a6248" font-size="7">Locorotondo</text>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>

<TerritoryModal client:visible />

<script>
  document.querySelectorAll('.territory-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const index = parseInt((btn as HTMLElement).dataset.index || '0', 10);
      window.dispatchEvent(new CustomEvent('open-territory', { detail: index }));
    });
  });
</script>
