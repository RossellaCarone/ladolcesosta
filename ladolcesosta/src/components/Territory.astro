---
import { places } from '../data/territory';
import TerritoryModal from './TerritoryModal.tsx';
import TerritoryMapInteractive from './TerritoryMapInteractive.tsx';
---

<section id="territorio" class="py-20 md:py-28 bg-beige/40">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="text-center mb-14 reveal">
      <h2 class="font-serif text-4xl md:text-5xl text-dark mb-4">Esplora il territorio</h2>
      <p class="font-sans text-earth/70 text-lg">Meraviglie pugliesi a pochi chilometri da La Dolce Sosta</p>
    </div>

    <div class="grid md:grid-cols-2 gap-12 items-start">
      <!-- Place list — compact 2-col grid -->
      <div class="reveal order-2 md:order-1">
        <div class="grid grid-cols-2 gap-2.5">
          {places.map((place, i) => (
            <button
              class="territory-btn text-left px-4 py-3 rounded-lg bg-cream/80 border border-sand/40 hover:border-accent/60 hover:shadow-md transition-colors duration-150 transition-shadow duration-200 group cursor-pointer"
              data-index={i}
            >
              <span class="font-serif text-sm text-dark group-hover:text-accent transition-colors leading-tight block">{place.name}</span>
              <p class="font-sans text-[11px] text-earth/60 mt-0.5 leading-snug">{place.shortDescription}</p>
              <span class="font-sans text-xs text-accent/70 font-medium mt-1 block">{place.distance}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Puglia map (interactive) -->
      <div class="reveal order-1 md:order-2 flex justify-center">
        <div class="w-full max-w-md md:max-w-lg">
          <TerritoryMapInteractive client:visible />
        </div>
      </div>
    </div>
  </div>
</section>

<TerritoryModal client:load />

<script>
  function initTerritoryButtons() {
    const btns = document.querySelectorAll('.territory-btn');
    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        const index = parseInt((btn as HTMLElement).dataset.index || '0', 10);
        window.dispatchEvent(new CustomEvent('open-territory', { detail: index }));
      });
      btn.addEventListener('mouseenter', () => {
        const index = parseInt((btn as HTMLElement).dataset.index || '0', 10);
        window.dispatchEvent(new CustomEvent('territory-hover', { detail: index }));
      });
      btn.addEventListener('mouseleave', () => {
        window.dispatchEvent(new CustomEvent('territory-hover', { detail: null }));
      });
    });

    window.addEventListener('territory-marker-hover', ((e: CustomEvent) => {
      const index = e.detail;
      document.querySelectorAll('.territory-btn').forEach((btn, i) => {
        if (index === i) {
          btn.classList.add('border-accent/60', 'shadow-md');
        } else {
          btn.classList.remove('border-accent/60', 'shadow-md');
        }
      });
    }) as EventListener);
  }

  // Ensure DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTerritoryButtons);
  } else {
    initTerritoryButtons();
  }
</script>
