---
import ReviewCarousel from './ReviewCarousel.tsx';
---

<section id="recensioni" class="py-20 md:py-28 bg-cream">
  <div class="max-w-6xl mx-auto px-6 md:px-10">
    <div class="text-center mb-12 reveal">
      <h2 class="font-serif text-4xl md:text-5xl text-dark mb-4">Cosa dicono i nostri <em>ospiti</em></h2>
      <p class="font-sans text-earth/70 text-lg">Esperienze autentiche dei nostri visitatori</p>
    </div>

    <div class="reveal">
      <ReviewCarousel client:visible />
    </div>
  </div>
</section>
