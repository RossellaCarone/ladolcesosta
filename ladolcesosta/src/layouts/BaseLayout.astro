---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'La Dolce Sosta — Casa Vacanze · Castellana Grotte, Puglia',
  description = 'Casa vacanze nel centro di Castellana Grotte, Puglia. 80m², 2 camere, cucina, 1-6 ospiti. A pochi passi dalle Grotte di Castellana e dalla Valle d\'Itria.',
} = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'VacationRental',
  name: 'La Dolce Sosta',
  description,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Via Luigi Cadorna 33',
    addressLocality: 'Castellana Grotte',
    postalCode: '70013',
    addressRegion: 'BA',
    addressCountry: 'IT',
  },
  identifier: {
    '@type': 'PropertyValue',
    name: 'CIN',
    value: 'IT072017C200123181',
  },
  numberOfRooms: 2,
  occupancy: {
    '@type': 'QuantitativeValue',
    minValue: 1,
    maxValue: 6,
  },
  floorSize: {
    '@type': 'QuantitativeValue',
    value: 80,
    unitCode: 'MTK',
  },
};
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="La Dolce Sosta" />
    <meta property="og:locale" content="it_IT" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Jost:wght@200;300;400&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />
  </body>
</html>
