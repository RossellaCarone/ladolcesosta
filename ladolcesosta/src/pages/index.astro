---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import MobileMenu from '../components/MobileMenu.tsx';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import About from '../components/About.astro';
import PhotoCarousel from '../components/PhotoCarousel.tsx';
import Amenities from '../components/Amenities.astro';
import Territory from '../components/Territory.astro';
import GoogleMap from '../components/GoogleMap.astro';
import Booking from '../components/Booking.astro';
import Reviews from '../components/Reviews.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout>
  <Nav />
  <MobileMenu client:media="(max-width: 900px)" />
  <Hero />
  <Stats />
  <About />

  <!-- Galleria fotografica -->
  <section id="gallery" class="py-20 md:py-28 bg-cream">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <div class="text-center mb-12 reveal">
        <h2 class="font-serif text-4xl md:text-5xl text-dark mb-4">I nostri spazi</h2>
        <p class="font-sans text-earth/70 text-lg">Scopri ogni angolo de La Dolce Sosta</p>
      </div>
      <div class="reveal">
        <PhotoCarousel client:visible />
      </div>
    </div>
  </section>

  <Amenities />

  <Territory />

  <GoogleMap />

  <Booking />

  <Reviews />

  <Contact />

  <Footer />

  <script>
    const revealObs = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));
  </script>
</BaseLayout>
